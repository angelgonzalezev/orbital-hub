# Use the hosted Supabase project values in production (for example, on Netlify).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Server-only. Add this as a secret in the hosting provider; never expose it with NEXT_PUBLIC_.
# Required for verified profile provisioning and local verification actions.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
ENABLE_DEV_VERIFICATION=false
NEXT_PUBLIC_ENABLE_DEV_VERIFICATION=false
